# Web API
ASPNETCORE_ENVIRONMENT=Development
HTTPS_PORT=8443
EXPOSE_443_PORT=true

# Storage Configuration
UPLOAD_STORAGE_PATH=/var/lib/modelibr/uploads

FRONTEND_PORT=3000
VITE_API_BASE_URL=/api
# HTTPS WebDAV port — also used as alias to the frontend over HTTPS.
# Use 443 for best Windows WebDAV compatibility (no registry edits needed).
WEBDAV_HTTPS_PORT=443
# HTTP WebDAV port — preferred for local networks (no TLS required).
# Windows \\server\modelibr resolves via HTTP on port 80 by default.
WEBDAV_HTTP_PORT=80

# PostgreSQL
POSTGRES_USER=modelibr
POSTGRES_PASSWORD=ChangeThisStrongPassword123!
POSTGRES_PORT=5432

# Asset Processor Service
WORKER_PORT=3001
WORKER_ID=worker-1
WORKER_API_KEY=change-me-to-a-secure-random-key
MAX_CONCURRENT_JOBS=3
RENDER_WIDTH=256
RENDER_HEIGHT=256
RENDER_FORMAT=png
LOG_LEVEL=info

# Thumbnail Storage
THUMBNAIL_STORAGE_ENABLED=true
THUMBNAIL_STORAGE_PATH=/var/lib/modelibr/thumbnails
SKIP_DUPLICATE_THUMBNAILS=true

# Blender (optional — for automatic .blend → .glb conversion)
# Option A: Bake Blender into the asset-processor Docker image at build time.
#   Set ENABLE_BLENDER=true and BLENDER_VERSION, then rebuild the image.
#   Blender will be available at /opt/blender/blender inside the container.
ENABLE_BLENDER=false
BLENDER_VERSION=5.0.1
# Option B: Download Blender at runtime via the Settings UI (no rebuild required).
#   The WebApi downloads the selected version into a shared Docker volume.
#   Override the install path with BLENDER_INSTALL_PATH if needed.
# BLENDER_INSTALL_PATH=/var/lib/modelibr/blender

# Docker (optional)
DOCKER_REGISTRY=
HOST_UID=1000
HOST_GID=1000
