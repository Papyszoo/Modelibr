{
  "name": "frontend",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "node scripts/prepare-demo-assets.js && node scripts/generate-demo-thumbnails.js && vite build --mode demo",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:webgl": "npx playwright test --config playwright.webgl.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "npx playwright test --config playwright.config.ts",
    "test-storybook:update": "npx playwright test --config playwright.config.ts --update-snapshots",
    "test-storybook:ci": "npx playwright test --config playwright.config.ts --reporter=github"
  },
  "dependencies": {
