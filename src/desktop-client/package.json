{
  "name": "modelibr-client",
  "private": true,
  "version": "0.3.0",
  "description": "Modelibr desktop client — an app window for a running Modelibr host",
  "homepage": "https://github.com/Papyszoo/Modelibr",
  "author": {
    "name": "Papyszoo",
    "email": "papyszoo@users.noreply.github.com"
  },
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir --publish never",
    "dist": "electron-builder --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.modelibr.client",
    "productName": "Modelibr Client",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "Papyszoo",
        "repo": "Modelibr"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Modelibr-Client-${version}-macos-${arch}.${ext}",
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Modelibr-Client-${version}-windows-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "Modelibr-Client-${version}-linux-${arch}.${ext}",
      "category": "Graphics"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
