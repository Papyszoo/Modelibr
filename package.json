{
    "name": "modelibr",
    "private": true,
    "version": "1.0.0",
    "description": "A modern 3D model file upload service built with .NET 9.0 and React",
    "type": "module",
    "scripts": {
        "lint": "cd src/frontend && npm run lint && cd ../asset-processor && npm run lint",
        "lint:fix": "cd src/frontend && npm run lint:fix && cd ../asset-processor && npm run lint:fix",
        "format": "cd src/frontend && npm run format && cd ../asset-processor && npm run format",
        "format:check": "cd src/frontend && npm run format:check && cd ../asset-processor && npm run format:check",
        "test:frontend": "cd src/frontend && npm test",
        "test:e2e": "cd tests/e2e && npm test",
        "test:e2e:demo": "cd tests/e2e && npm run test:demo",
        "test:all": "node scripts/test-runner/index.mjs",
        "test:all:fast": "node scripts/test-runner/index.mjs --tier=fast --yes",
        "test:all:full": "node scripts/test-runner/index.mjs --all --yes",
        "test:audit": "node scripts/test-runner/discover.mjs",
        "test:catalog": "node scripts/test-catalog/build-catalog.mjs",
        "test:site": "node scripts/test-catalog/build-catalog.mjs && node scripts/test-catalog/server.mjs",
        "test:site:fast": "node scripts/test-catalog/build-catalog.mjs --no-github && node scripts/test-catalog/server.mjs",
        "build:frontend": "cd src/frontend && npm run build"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Papyszoo/Modelibr.git"
    },
    "keywords": [
        "3d-models",
        "file-upload",
        "react",
        "dotnet",
        "clean-architecture"
    ],
    "author": "Modelibr Team",
    "license": "BUSL-1.1",
    "devDependencies": {
        "playwright-bdd": "^8.4.2"
    }
}
